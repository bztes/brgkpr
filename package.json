{
  "name": "brgkpr",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "docker:build": "docker build -t brgkpr .",
    "docker:run": "docker run --env-file .env -v ./tmp/data:/app/tmp/data --network=host -e ORIGIN=http://localhost:3000 brgkpr",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:schema": "pnpm dlx auth@latest generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^7.0.11",
    "@types/ssh2": "^1.15.5",
    "@types/sshpk": "^1.17.4",
    "@vitest/browser-playwright": "^4.0.18",
    "bits-ui": "^2.16.2",
    "clsx": "^2.1.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.6",
    "svelte-check": "^4.4.4",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-browser-svelte": "^2.0.2"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "better-auth": "^1.5.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "fast-json-stable-stringify": "^2.1.0",
    "node-ssh": "^13.2.1",
    "nodemailer": "^8.0.1",
    "sshpk": "^1.18.0",
    "zod": "^4.3.6"
  }
}
